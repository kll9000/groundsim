<Window x:Class="GroundSim.Render.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GroundSim — Colony Prototype"
        Width="1600" Height="900" Background="#181A22">
    <!-- Fixed window size (not SizeToContent): the Phase 10 camera-shift bug
         was the window resizing to track the status text's fluctuating width
         and re-centering the image. Window size is now never content-driven. -->
    <DockPanel>
        <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom"
                   Foreground="#CCCCCC" FontFamily="Consolas" Margin="6,3"
                   TextTrimming="CharacterEllipsis" Text="starting..."/>
        <Grid>
            <Border x:Name="ViewportHost" ClipToBounds="True" Background="#101218"
                    Focusable="True">
                <Image x:Name="SurfaceImage" Stretch="None"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ZoomTransform"/>
                            <TranslateTransform x:Name="PanTransform"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>
            </Border>
            <!-- Phase 16: color legend. Overlay (not part of the world
                 bitmap), semi-transparent, top-right, hit-test invisible so
                 camera drag/click passes straight through; toggled with L.
                 Populated in code-behind from GridRenderer.LegendEntries so
                 it always matches the renderer's actual constants. -->
            <Border x:Name="LegendPanel" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,10,10,0" Background="#D9181A22" BorderBrush="#44FFFFFF"
                    BorderThickness="1" CornerRadius="4" Padding="10,8"
                    IsHitTestVisible="False">
                <StackPanel x:Name="LegendStack"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
